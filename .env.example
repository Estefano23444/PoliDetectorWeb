# Copia este archivo como ".env" para desarrollo local (NO se sube a git).
# En Vercel: configura esta misma variable en Project Settings > Environment Variables.

# Clave de la API de Google Gemini (obtenla gratis en https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=tu_clave_aqui

# (Opcional) Modelo de Gemini a usar. Por defecto: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash
